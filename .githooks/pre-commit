#!/usr/bin/env bash
set -euo pipefail

if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact --no-banner --exit-code 1
  exit 0
fi

if command -v docker >/dev/null 2>&1; then
  docker run --rm -v "$PWD":/repo -w /repo zricethezav/gitleaks:latest protect --staged --redact --no-banner --exit-code 1
  exit 0
fi

echo "gitleaks not found. Install gitleaks (https://github.com/gitleaks/gitleaks) or Docker to run the fallback image." >&2
exit 1
