# syntax=docker/dockerfile:1.7
FROM node:20-bookworm-slim

ARG HOST_UID=1000
ARG HOST_GID=1000
ARG TANDEM_RELEASE_VERSION=latest
ARG TANDEM_ENGINE_RELEASE_VERSION=${TANDEM_RELEASE_VERSION}
ARG VERSION=dev
ARG VCS_REF=unknown
ARG BUILD_DATE=unknown

ENV DEBIAN_FRONTEND=noninteractive \
    NPM_CONFIG_PREFIX=/home/node/npm \
    npm_config_update_notifier=false

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update \
  && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    chromium \
    libssl3 \
  && rm -rf /var/lib/apt/lists/*

RUN --mount=type=cache,target=/root/.npm \
    npm install -g "@frumu/tandem@${TANDEM_ENGINE_RELEASE_VERSION}"

RUN mkdir -p /home/node/.local/share/tandem /workspace/tandem-data \
  && chown node:node /home/node/.local/share/tandem /workspace/tandem-data

ENV PATH="/home/node/npm/bin:${PATH}"
ENV TANDEM_BROWSER_EXECUTABLE=/usr/bin/chromium

COPY --chown=${HOST_UID}:${HOST_GID} scripts/tandem-engine-serve.sh /usr/local/bin/tandem-engine-serve.sh
COPY --chown=${HOST_UID}:${HOST_GID} scripts/tandem-mcp-bootstrap.js /usr/local/lib/tandem-mcp-bootstrap.js
RUN chmod +x /usr/local/bin/tandem-engine-serve.sh

COPY LICENSE /LICENSE
COPY NOTICE /NOTICE

LABEL org.opencontainers.image.title="Tandem Engine" \
      org.opencontainers.image.description="Standalone Tandem engine sidecar" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.revision="${VCS_REF}" \
      org.opencontainers.image.created="${BUILD_DATE}"

EXPOSE 39733

CMD ["/usr/local/bin/tandem-engine-serve.sh"]
