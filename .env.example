# ACA portable auto-coder bootstrap environment
#
# Copy this file to `.env`, then run `./scripts/setup.sh`.
# The control panel now owns most non-secret install state in
# `tandem-data/control-panel-config.json`.

# Compose project name (controls container/network names)
COMPOSE_PROJECT_NAME=tandem-agents

# Tandem engine bootstrap
TANDEM_RELEASE_VERSION=latest
TANDEM_ENGINE_RELEASE_VERSION=latest
TANDEM_CONTROL_PANEL_RELEASE_VERSION=latest
TANDEM_BASE_URL=
TANDEM_PORT=39733
TANDEM_ENGINE_HOST=0.0.0.0
TANDEM_ENGINE_PORT=39733
TANDEM_API_TOKEN_FILE=./tandem-data/tandem_api_token
TANDEM_ENGINE_COMMAND=scripts/tandem-engine-serve.sh
TANDEM_STATE_DIR=./tandem-engine-state

# Tandem control panel bootstrap
TANDEM_CONTROL_PANEL_PORT=39734
TANDEM_CONTROL_PANEL_HOST=127.0.0.1
TANDEM_CONTROL_PANEL_PUBLIC_URL=
TANDEM_CONTROL_PANEL_STATE_DIR=./tandem-data/control-panel
TANDEM_CONTROL_PANEL_CONFIG_FILE=./tandem-data/control-panel-config.json
TANDEM_CONTROL_PANEL_MODE=auto
TANDEM_CONTROL_PANEL_AUTO_START_ENGINE=1
# Enable hosted-managed UI flows such as Codex auth.json import.
TANDEM_HOSTED_MANAGED=false

# Local knowledgebase MCP bootstrap
KB_PORT=39736
KB_PUBLIC_BASE_URL=http://127.0.0.1:39736/mcp
KB_DOCS_ROOT=./kb-data/docs
KB_INDEX_ROOT=./kb-data/index
KB_ADMIN_API_KEY_FILE=./secrets/kb_admin_api_key
# Optional YAML seed for KB agent prompts. Loaded ONCE on first startup.
# After that, the KB persists a sentinel row marking "seeded" — subsequent
# restarts ignore this file entirely, even if the owner has reset every
# override back to the built-in defaults via the control panel. Manage
# prompts through the control panel "Agent prompts" panel after first boot.
# See config/kb_prompts.yaml.example for the schema.
# KB_PROMPTS_FILE=./config/kb_prompts.yaml
ACA_KB_MCP_ENABLED=true

# ACA control plane bootstrap
ACA_MODE=api
ACA_API_PORT=39735
ACA_API_TOKEN_FILE=./tandem-data/aca_api_token
# Strict-token mode (default true). When true, the API server refuses to
# start if no ACA_API_TOKEN / ACA_API_TOKEN_FILE is configured. Set to
# false ONLY for local development where you intentionally want an
# unauthenticated API; production deployments should leave this on.
# ACA_API_REQUIRE_TOKEN=true

# Storage profile for coordination state
# local = SQLite on the current machine
# shared = Postgres-backed coordination for shared deployments
ACA_STORAGE_PROFILE=local
ACA_COORDINATION_POSTGRES_URL=
ACA_COORDINATION_POSTGRES_DB=aca
ACA_COORDINATION_POSTGRES_USER=aca
ACA_COORDINATION_POSTGRES_PASSWORD=aca
ACA_COORDINATION_POSTGRES_PORT=5432

# Review policy
# human_review = keep the PR merge gate manual
# auto_merge = allow guarded ACA finalization after clean checks/review are proven.
# Merge and branch deletion still require explicit approvals by default. Set
# the approval gates to false only for unattended finalization.
ACA_REVIEW_POLICY=human_review
ACA_AUTO_MERGE_STRATEGY=squash
ACA_AUTO_MERGE_ALLOWED_STRATEGIES=squash
ACA_MERGE_REQUIRES_APPROVAL=true
ACA_BRANCH_DELETE_REQUIRES_APPROVAL=true
ACA_DELETE_BRANCH_AFTER_MERGE=true

# Coder backend supervision
# Some real code tasks run for 30-60 minutes; ACA should keep polling Tandem
# instead of treating a slow non-terminal coder run as failed after a few minutes.
#
# Operational note: this is the maximum a hung coder subprocess will block a
# run before being treated as failed. On shared deployments where a stalled
# run blocks the queue for other tasks, prefer a tighter value (600-1200s).
# On dedicated single-task deployments the default is fine.
ACA_CODER_WAIT_TIMEOUT_SECONDS=3600
ACA_CODER_POLL_INTERVAL_SECONDS=15
ACA_CODER_SUPERVISOR_ENABLED=true
ACA_CODER_SUPERVISOR_INTERVAL_SECONDS=30
ACA_CODER_SUPERVISOR_BATCH_SIZE=100
ACA_CODER_CANCEL_ON_SOURCE_TERMINAL=true

# Scheduler policy for parallel task admission
# fair_round_robin = admit tasks across projects conservatively and avoid repo overlap
ACA_SCHEDULER_POLICY=fair_round_robin
ACA_SCHEDULER_MAX_ACTIVE_TASKS=4
ACA_SCHEDULER_MAX_ACTIVE_TASKS_PER_PROJECT=1
ACA_SCHEDULER_MAX_ACTIVE_TASKS_PER_REPO=1
ACA_SCHEDULER_QUEUE_DEPTH_LIMIT=50

# Linear task-source integration
# Linear OAuth is owned by the Tandem control panel MCP connection. ACA uses
# the connected server name and never stores a Linear API token here.
ACA_LINEAR_MCP_ENABLED=false
ACA_LINEAR_MCP_SERVER=linear
ACA_LINEAR_MCP_SCOPE=intake_finalize
ACA_LINEAR_REMOTE_SYNC=rich
ACA_LINEAR_CLAIM_LABEL=aca-running
ACA_LINEAR_DONE_LABEL=aca-done
ACA_LINEAR_BLOCKED_LABEL=aca-blocked
ACA_LINEAR_CLAIM_STATUS=In Progress
ACA_LINEAR_REVIEW_STATUS=In Review
ACA_LINEAR_DONE_STATUS=Done
ACA_LINEAR_BLOCKED_STATUS=Blocked

# Artifact store for mirrored run outputs and recovery
# leave empty to use the local default under the output root
ACA_ARTIFACT_STORE_ROOT=

# Host-side runtime directories
ACA_HOST_UID=
ACA_HOST_GID=
ACA_WORKSPACE_HOST_DIR=./workspace
ACA_LOCAL_REPOS_DIR=./test-repos

# Optional GitHub / provider secrets
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_TOKEN=
GITHUB_PERSONAL_ACCESS_TOKEN_FILE=./secrets/github_token
GITHUB_TOKEN_FILE=./secrets/github_token
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
COHERE_API_KEY=
